# ============================================================
# Likes Local - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Your API key from likes app (Settings → Apply API Key)
VITE_API_KEY=lt_your_api_key_here

# Remote API base URL (default: https://my.likes.com.cn)
VITE_API_BASE_URL=https://my.likes.com.cn

# App display name (default: Likes Local)
VITE_APP_NAME=Likes Local

# Optional password to protect the local app
# Leave empty to disable password protection
VITE_APP_PASSWORD=

# Default language: zh (Chinese) or en (English)
VITE_LOCALE=zh

# Default theme color (hex)
VITE_THEME_COLOR=#3b82f6
