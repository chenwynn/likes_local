{
  "name": "likes-local",
  "version": "0.1.0",
  "description": "Local-first Likes frontend desktop/web app.",
  "author": "likes_local",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:electron": "VITE_ELECTRON=1 sh -c 'vue-tsc && vite build'",
    "preview": "vite preview",
    "desktop:dist": "npm run build:electron && electron-builder --publish never",
    "desktop:pack": "npm run build:electron && electron-builder --dir --publish never"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/roboto": "^5.2.10",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "dexie": "^4.3.0",
    "echarts": "^5.6.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.0",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.7.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "sass": "^1.83.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.11",
    "vite-plugin-vuetify": "^2.0.4",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "cn.likes.local",
    "productName": "Likes Local",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "pkg"
      ],
      "identity": null,
      "category": "public.app-category.healthcare-fitness"
    },
    "linux": {
      "icon": "build/icons/512x512.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
